<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Header -->
    <TextView
        android:id="@+id/dialogCourseTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CIS 2203N"
        android:textColor="#0A1931"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/dialogCourseName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Mobile Development"
        android:textColor="#666666"
        android:textSize="14sp" />

    <!-- Overall GPA -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Overall GPA: "
            android:textColor="#0A1931"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/dialogGpaValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3.50"
            android:textColor="#2E7D32"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/dialogLetterGrade"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="(A)"
            android:textColor="#666666"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="12dp"
        android:background="#E5E7EB" />

    <!-- Detailed Scores Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Detailed Scores"
        android:textColor="#0A1931"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- Scroll View for Scores -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:maxHeight="300dp">

        <LinearLayout
            android:id="@+id/scoresContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">


        </LinearLayout>

    </ScrollView>

    <!-- Close Button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/closeButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/button_blue_bg"
        android:text="Close"
        android:textColor="@color/white"
        android:textStyle="bold" />

</LinearLayout>
